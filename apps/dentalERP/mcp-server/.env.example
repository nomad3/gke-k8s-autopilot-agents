# MCP Server Environment Configuration

# Server
HOST=0.0.0.0
PORT=8085
ENVIRONMENT=development
DEBUG=true

# Security
MCP_API_KEY=your-secure-mcp-api-key-min-32-characters-long
SECRET_KEY=your-secret-key-for-jwt-signing-min-32-chars

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mcp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/mcp

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Alert Notifications (Optional)
# Slack Webhook (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email SMTP Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@dentalerp.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=DentalERP Alerts <alerts@dentalerp.com>
ALERT_EMAIL=executives@example.com
